# Completion for git-test (bash and zsh compatible)

if [ -n "$ZSH_VERSION" ]; then
    # Zsh completion
    _git-test() {
        local -a subcommands refs
        subcommands=('setup:setup test configuration')

        if (( CURRENT == 2 )) && [[ "$words[2]" == "setup" || "$words[2]" == -* ]]; then
            _describe 'command' subcommands
        elif (( CURRENT == 3 )) && [[ "$words[2]" == "setup" ]]; then
            local -a remotes
            remotes=(${(f)"$(git remote 2>/dev/null)"})
            _describe 'remote' remotes
        else
            # Complete with git refs (branches, tags, commits)
            refs=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads refs/tags 2>/dev/null)"})
            _describe 'ref' refs
        fi
    }
else
    # Bash completion
    _git_test() {
        local subcommands="setup"
        local cur="${COMP_WORDS[COMP_CWORD]}"
        local prev="${COMP_WORDS[COMP_CWORD-1]}"

        if [ $COMP_CWORD -eq 1 ] && [[ "$cur" == -* || "$cur" == "setup" ]]; then
            COMPREPLY=($(compgen -W "$subcommands" -- "$cur"))
        elif [ "$prev" = "setup" ]; then
            # Complete with git remotes
            COMPREPLY=($(compgen -W "$(git remote 2>/dev/null)" -- "$cur"))
        else
            # Complete with refs for the commit ref argument
            __git_complete_refs
        fi
    }
fi
