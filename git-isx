#!/bin/bash
# Pull from and push to repos in incus-spawn instances,
# rebasing commits as necessary to sign them.
# Also creates PRs using git-pr.
# See https://github.com/Sanne/incus-spawn/

source $(readlink -f ${BASH_SOURCE[0]} | xargs dirname)/lib/common.sh

function usage() {
	log 'Usage:'
	log -e '\tgit isx get [<name>]'
	log -e 'OR'
	log -e '\tgit isx put [<name>]'
	log -e 'OR'
	log -e '\tgit isx pr [<name>]'
	log ''
	log 'If <name> is not provided, uses the current branch name.'
	abort
}

function get_git_directory_name() {
	basename "$(git rev-parse --show-toplevel)"
}

function get_base_branch() {
	# Determine base branch from the remote-tracking branch of the local default branch
	local BASE_REMOTE

	# Prefer upstream if it exists, otherwise use origin
	if git remote | grep -q '^upstream$'
	then
		BASE_REMOTE="upstream"
	else
		BASE_REMOTE="origin"
	fi

	# Get the default branch from the remote
	if ! BASE_BRANCH=$(git rev-parse --abbrev-ref "$BASE_REMOTE/HEAD" 2>/dev/null)
	then
		# Maybe the remote HEAD was not set yet, try to set it automatically
		git remote set-head -a "$BASE_REMOTE" 1>&2
		BASE_BRANCH=$(git rev-parse --abbrev-ref "$BASE_REMOTE/HEAD")
	fi

	echo "$BASE_BRANCH"
}

function run_on_isx_remote() {
	local REMOTE_NAME="$1"
	local BASH_CMD="$2"

	local REMOTE_URL
	REMOTE_URL=$(git remote get-url "$REMOTE_NAME")

	local ISX_PART="${REMOTE_URL#isx://}"
	local INSTANCE="${ISX_PART%%/*}"
	local REPO_PATH="${ISX_PART#*/}"
	# Mirror GitRemoteUtils.expandContainerTilde: ~/... -> /home/agentuser/...
	REPO_PATH="${REPO_PATH/#~//home/agentuser}"

	incus exec "$INSTANCE" --user 1000 --cwd "/home/agentuser" -- bash -c "cd $REPO_PATH && $BASH_CMD"
}

function push_to_isx_remote() {
	local REMOTE_NAME="$1"
	local BRANCH_NAME="$2"
	local REMOTE_DEFAULT_BRANCH="$3"

	local LOCAL_SHA
	LOCAL_SHA=$(git rev-parse HEAD)
	local REMOTE_SHA
	REMOTE_SHA=$(git rev-parse "$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH" 2>/dev/null || echo "")

	if [ "$LOCAL_SHA" != "$REMOTE_SHA" ]
	then
		log "Pushing to '$REMOTE_NAME/$BRANCH_NAME'..."
		git push --force "$REMOTE_NAME" "HEAD:$BRANCH_NAME" \
			|| abort "Error pushing to '$REMOTE_NAME/$BRANCH_NAME'."

		log "Resetting '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH' to '$BRANCH_NAME'..."
		run_on_isx_remote "$REMOTE_NAME" "git reset --hard $BRANCH_NAME" \
			|| abort "Error resetting working tree on '$REMOTE_NAME'."
	else
		log "Remote '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH' is already up to date, skipping push."
	fi
}

function get_remote_default_branch() {
	local REMOTE_NAME="$1"
	local DEFAULT_BRANCH

	if ! DEFAULT_BRANCH=$(git rev-parse --abbrev-ref "$REMOTE_NAME/HEAD" 2>/dev/null)
	then
		git remote set-head -a "$REMOTE_NAME" 1>&2
		DEFAULT_BRANCH=$(git rev-parse --abbrev-ref "$REMOTE_NAME/HEAD")
	fi

	echo "${DEFAULT_BRANCH#"$REMOTE_NAME/"}"
}

function resolve_remote_name() {
	local NAME="$1"
	local GIT_DIR_NAME="$2"

	if git remote get-url "$NAME" >/dev/null 2>&1
	then
		echo "$NAME"
	elif git remote get-url "$GIT_DIR_NAME-$NAME" >/dev/null 2>&1
	then
		echo "$GIT_DIR_NAME-$NAME"
	else
		abort "No remote found for '$NAME' (tried '$NAME' and '$GIT_DIR_NAME-$NAME'). Maybe the incus-spawn instance doesn't exist?"
	fi
}

function get_branch() {
	local NAME="$1"
	local BRANCH_NAME="$2"

	local GIT_DIR_NAME
	GIT_DIR_NAME="$(get_git_directory_name)"

	local REMOTE_NAME
	REMOTE_NAME="$(resolve_remote_name "$NAME" "$GIT_DIR_NAME")"

	# Fetch the remote
	log "Fetching remote '$REMOTE_NAME'..."
	git fetch -p "$REMOTE_NAME"

	local REMOTE_DEFAULT_BRANCH
	REMOTE_DEFAULT_BRANCH="$(get_remote_default_branch "$REMOTE_NAME")"

	if git rev-parse --quiet --verify "refs/heads/$BRANCH_NAME" >/dev/null 2>&1
	then
		# Branch exists - checkout and rebase
		log "Branch '$BRANCH_NAME' exists locally, checking out and rebasing..."

		git checkout "$BRANCH_NAME" \
			|| abort "Error while checking out branch '$BRANCH_NAME'."

		# Reset to the remote's default branch
		git fetch "$REMOTE_NAME" "$REMOTE_DEFAULT_BRANCH":refs/remotes/"$REMOTE_NAME"/"$REMOTE_DEFAULT_BRANCH" \
			|| abort "Error fetching '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH'."

		log "Resetting to '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH'..."
		git reset --hard "$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH" \
			|| abort "Error resetting to '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH'."

		# Non-interactive rebase on default branch
		local BASE_BRANCH
		BASE_BRANCH="$(get_base_branch)"

		# Fetch the base branch first
		local BASE_REMOTE
		BASE_REMOTE=$(echo "$BASE_BRANCH" | cut -d/ -f1)
		local BASE_BRANCH_NAME
		BASE_BRANCH_NAME=$(echo "$BASE_BRANCH" | cut -d/ -f2)
		git fetch "$BASE_REMOTE" "$BASE_BRANCH_NAME" \
			|| abort "Error fetching '$BASE_BRANCH'."

		COMMIT_COUNT=$(git rev-list --count "$BASE_BRANCH..HEAD")
		if [ "$COMMIT_COUNT" -gt 0 ]
		then
			log "Rebasing on '$BASE_BRANCH' ($COMMIT_COUNT commits)..."
			git rebase "$BASE_BRANCH" \
				|| abort "Error during rebase on '$BASE_BRANCH'. Please resolve conflicts and complete the rebase manually."
		else
			log "Already up to date with '$BASE_BRANCH', skipping rebase."
		fi

	else
		# Branch doesn't exist - create from remote's default branch
		log "Branch '$BRANCH_NAME' doesn't exist locally, creating from '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH'..."

		# Create branch from remote's default branch without setting up tracking
		git checkout -b "$BRANCH_NAME" --no-track "$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH" \
			|| abort "Error while creating branch '$BRANCH_NAME' from '$REMOTE_NAME/$REMOTE_DEFAULT_BRANCH'."

		# Rebase on upstream/main or origin/main
		local BASE_BRANCH
		BASE_BRANCH="$(get_base_branch)"

		# Fetch the base branch first
		local BASE_REMOTE
		BASE_REMOTE=$(echo "$BASE_BRANCH" | cut -d/ -f1)
		local BASE_BRANCH_NAMEPushin
		BASE_BRANCH_NAME=$(echo "$BASE_BRANCH" | cut -d/ -f2)
		git fetch "$BASE_REMOTE" "$BASE_BRANCH_NAME" \
			|| abort "Error fetching '$BASE_BRANCH'."

		local COMMIT_COUNT
		COMMIT_COUNT=$(git rev-list --count "$BASE_BRANCH..HEAD")
		if [ "$COMMIT_COUNT" -gt 0 ]
		then
			log "Rebasing on '$BASE_BRANCH' ($COMMIT_COUNT commits)..."
			git rebase "$BASE_BRANCH" \
				|| abort "Error during rebase on '$BASE_BRANCH'. Please resolve conflicts and complete the rebase manually."
		else
			log "Already up to date with '$BASE_BRANCH', skipping rebase."
		fi
	fi

	# Push the result back to the source remote if there are changes
	push_to_isx_remote "$REMOTE_NAME" "$BRANCH_NAME" "$REMOTE_DEFAULT_BRANCH"

	log "Successfully checked out and rebased branch '$BRANCH_NAME'."
}

function put_branch() {
	local NAME="$1"
	local BRANCH_NAME="$2"

	local GIT_DIR_NAME
	GIT_DIR_NAME="$(get_git_directory_name)"

	local REMOTE_NAME
	REMOTE_NAME="$(resolve_remote_name "$NAME" "$GIT_DIR_NAME")"

	# Fetch the remote to ensure we have the latest state
	log "Fetching remote '$REMOTE_NAME'..."
	git fetch -p "$REMOTE_NAME"

	local REMOTE_DEFAULT_BRANCH
	REMOTE_DEFAULT_BRANCH="$(get_remote_default_branch "$REMOTE_NAME")"

	push_to_isx_remote "$REMOTE_NAME" "$BRANCH_NAME" "$REMOTE_DEFAULT_BRANCH"

	log "Successfully pushed branch '$BRANCH_NAME'."
}

# Main script logic
if [ "$1" == 'get' ]
then
	shift
	(( $# <= 1 )) || usage

	if [ -n "$1" ]
	then
		NAME="$1"
		BRANCH_NAME="$1"
	else
		# Use current branch name
		BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
		NAME="$BRANCH_NAME"
	fi

	get_branch "$NAME" "$BRANCH_NAME"

	success "Successfully checked out and rebased branch '$BRANCH_NAME'."
elif [ "$1" == 'put' ]
then
	shift
	(( $# <= 1 )) || usage

	if [ -n "$1" ]
	then
		NAME="$1"
		BRANCH_NAME="$1"
	else
		# Use current branch name
		BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
		NAME="$BRANCH_NAME"
	fi

	put_branch "$NAME" "$BRANCH_NAME"

	success "Successfully pushed branch '$BRANCH_NAME'."
elif [ "$1" == 'pr' ]
then
	shift
	(( $# <= 1 )) || usage

	if [ -n "$1" ]
	then
		NAME="$1"
		BRANCH_NAME="$1"
	else
		# Use current branch name
		BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
		NAME="$BRANCH_NAME"
	fi

	get_branch "$NAME" "$BRANCH_NAME"

	# Check if the branch has a remote-tracking branch set up
	if ! git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1
	then
		log "Initializing fork branch (setting up remote tracking)..."
		git fork branch init \
			|| abort "Error initializing fork branch."
	else
		# Remote tracking already set up, just force push
		FORK_REMOTE="$(git fork get remote)"
		log "Force pushing to fork remote '$FORK_REMOTE'..."
		git push -f "$FORK_REMOTE" "$BRANCH_NAME" \
			|| abort "Error force pushing to fork remote."
	fi

	log "Creating pull request..."
	git pr create \
		|| abort "Error creating pull request."

	success "Successfully created pull request for branch '$BRANCH_NAME'."
else
	usage
fi
